{
    "schemas": {
        "daily_activity_summary": {
            "description": "Aggregated daily activity data for streak tracking",
            "fields": {
                "user_id": {
                    "type": "string",
                    "required": true
                },
                "date": {
                    "type": "string",
                    "format": "date",
                    "required": true
                },
                "activity_count": {
                    "type": "integer",
                    "default": 0
                },
                "has_activity": {
                    "type": "boolean",
                    "default": false
                },
                "last_modified": {
                    "type": "timestamp"
                }
            }
        },
        "challenges": {
            "description": "Neighborhood challenge definitions",
            "fields": {
                "challenge_id": {
                    "type": "string",
                    "required": true
                },
                "creator_id": {
                    "type": "string",
                    "required": true
                },
                "title": {
                    "type": "string",
                    "required": true
                },
                "goal_type": {
                    "type": "string",
                    "enum": [
                        "distance",
                        "duration",
                        "steps",
                        "custom"
                    ]
                },
                "goal_value": {
                    "type": "number",
                    "required": true
                },
                "goal_unit": {
                    "type": "string",
                    "required": true
                },
                "participants": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "progress": {
                    "type": "object"
                },
                "area": {
                    "type": "string",
                    "required": true
                },
                "start_date": {
                    "type": "string",
                    "format": "date"
                },
                "end_date": {
                    "type": "string",
                    "format": "date"
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "active",
                        "completed",
                        "archived"
                    ]
                },
                "sync_status": {
                    "type": "string",
                    "enum": [
                        "pending",
                        "synced"
                    ]
                },
                "last_modified": {
                    "type": "timestamp"
                }
            }
        },
        "injury_log": {
            "description": "Local injury and recovery tracking",
            "fields": {
                "injury_id": {
                    "type": "string",
                    "required": true
                },
                "date": {
                    "type": "string",
                    "format": "date",
                    "required": true
                },
                "description": {
                    "type": "string",
                    "required": true
                },
                "severity": {
                    "type": "string",
                    "enum": [
                        "mild",
                        "moderate",
                        "severe"
                    ]
                },
                "rest_days": {
                    "type": "integer"
                },
                "physio_exercises": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "active",
                        "recovered"
                    ]
                },
                "notes": {
                    "type": "string"
                },
                "created_at": {
                    "type": "timestamp"
                },
                "updated_at": {
                    "type": "timestamp"
                }
            }
        },
        "survey_responses": {
            "description": "Anonymous survey responses",
            "fields": {
                "response_id": {
                    "type": "string",
                    "required": true
                },
                "survey_id": {
                    "type": "string",
                    "required": true
                },
                "answers": {
                    "type": "object",
                    "required": true
                },
                "location_area": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "integer"
                },
                "sync_status": {
                    "type": "string",
                    "enum": [
                        "pending",
                        "synced"
                    ]
                }
            }
        },
        "habits": {
            "description": "Habit chain definitions",
            "fields": {
                "habit_id": {
                    "type": "string",
                    "required": true
                },
                "name": {
                    "type": "string",
                    "required": true
                },
                "description": {
                    "type": "string"
                },
                "reminder_enabled": {
                    "type": "boolean",
                    "default": false
                },
                "reminder_time": {
                    "type": "string",
                    "format": "time"
                },
                "created_at": {
                    "type": "timestamp"
                },
                "streak": {
                    "type": "integer",
                    "default": 0
                },
                "longest_streak": {
                    "type": "integer",
                    "default": 0
                },
                "last_completed_date": {
                    "type": "string",
                    "format": "date"
                }
            }
        },
        "habit_logs": {
            "description": "Daily logs for habits",
            "fields": {
                "log_id": {
                    "type": "string",
                    "required": true
                },
                "habit_id": {
                    "type": "string",
                    "required": true
                },
                "date": {
                    "type": "string",
                    "format": "date",
                    "required": true
                },
                "completed": {
                    "type": "boolean",
                    "default": true
                }
            }
        },
        "participation_stats": {
            "description": "Aggregated community participation stats",
            "fields": {
                "location_type": {
                    "type": "string",
                    "enum": [
                        "area",
                        "city",
                        "region",
                        "nation"
                    ]
                },
                "location_code": {
                    "type": "string",
                    "required": true
                },
                "active_users_last_7days": {
                    "type": "integer",
                    "default": 0
                },
                "last_updated": {
                    "type": "timestamp"
                }
            }
        }
    }
}